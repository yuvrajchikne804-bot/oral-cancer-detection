# Ignore node_modules directory so we do not copy local/host dependencies into the container.
# The container will install its own platform-specific dependencies during build.
node_modules/

# Ignore local build outputs to prevent mixing local built files with container context.
dist/
build/

# Ignore local environment variables and secrets to prevent leaking keys/sensitive info.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore package manager error/debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore Git directory and config
.git/
.gitignore

# Ignore editor-specific configurations
.vscode/
.idea/
.oxlintrc.json
